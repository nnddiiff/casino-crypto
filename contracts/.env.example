# --- Деплой на Base Sepolia ---

# RPC-endpoint. Публичный дефолт ниже работает; под нагрузку — Alchemy/Infura.
# Резерв при rate-limit официального RPC: https://84532.rpc.thirdweb.com
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Приватный ключ кошелька-деплоера.
# ТОЛЬКО тестовый кошелёк, без реальных средств. Никогда не коммитить.
PRIVATE_KEY=

# Etherscan API-ключ для верификации (единый Etherscan V2 — работает и для Basescan).
# Брать на etherscan.io. Ключи basescan.org (V1) отключены с 15.08.2025.
ETHERSCAN_API_KEY=

# --- Зафиксированные адреса (Base Sepolia, chain id 84532) ---

# Pyth Entropy — источник проверяемой случайности.
# Источник: конфиг деплоев pyth-network/pyth-crosschain. Не менять без причины.
ENTROPY_ADDRESS=0x41c9e39574F40Ad34c79f1C99B66A45eFB830d4c

# --- Опционально: начальное пополнение при деплое (wei) ---
# Если заданы — деплой-скрипт сразу пополнит банк/кран из кошелька деплоера.
BANK_SEED_WEI=
FAUCET_SEED_WEI=
